{
    "name": "bmd\/wp-framework",
    "description": "Generic WordPress framework plugin",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Bob Moore"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": false,
        "vendor-dir": "vendor",
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {
            "composer\/installers": true,
            "dealerdirect\/phpcodesniffer-composer-installer": true,
            "phpstan\/extension-installer": true,
            "wpify/scoper": true
        }
    },
    "autoload": {
        "psr-4": {
            "Bmd\\WPFramework\\": "inc",
            "Bmd\\WPFramework\\PHPUnit\\": "tests/phpunit"
        }
    },
    "require-dev": {
        "squizlabs\/php_codesniffer": "^3.7",
        "phpunit\/phpunit": "^9.6",
        "symfony\/var-dumper": "*",
        "wp-coding-standards\/wpcs": "^3.0",
        "phpstan\/phpstan": "^1.10",
        "szepeviktor\/phpstan-wordpress": "^1.3",
        "phpcsstandards\/phpcsutils": "^1.0",
        "10up\/wp_mock": "*",
        "wpify/scoper": "^3.2"
    },
    "scripts": {
        "phpstan": ".\/vendor\/bin\/phpstan analyze -c .\/tests\/phpstan.neon --memory-limit=2048M",
        "phpsniff": ".\/vendor\/bin\/phpcs .\/inc -v --standard='.\/tests\/phpcs.xml'",
        "phpsniff:fix": ".\/vendor\/bin\/phpcbf .\/inc -v --standard='.\/tests\/phpcs.xml'",
        "phpsniff:default": ".\/vendor\/bin\/phpcs .\/inc -v",
        "phpsniff:PSR12": ".\/vendor\/bin\/phpcs .\/inc -v --standard='PSR12'",
        "phpsniff:PSR2": ".\/vendor\/bin\/phpcs .\/inc -v --standard='PSR2'",
        "phpsniff:WP": ".\/vendor\/bin\/phpcs .\/inc -v --standard='WordPress'",
        "phpunit": ".\/vendor\/bin\/phpunit --configuration .\/tests\/phpunit.xml --verbose"
    },
    "require": {
        "php-di\/php-di": "*"
    },
    "extra": {
        "wpify-scoper": {
            "prefix": "Bmd\\WPFramework",
            "slug": "bmd_wp_framework",
            "folder": "./vendor/scoped",
            "globals": [
                "wordpress",
                "woocommerce"
            ],
            "composerjson": "composer-deps.json",
            "composerlock": "composer-deps.lock",
            "autorun": false
        }
    },
    "archive": {
        "exclude": [
            "*",
            ".*",
            "!/inc/",
            "!/inc/**",
            "!/composer.json"
        ]
    }
}
