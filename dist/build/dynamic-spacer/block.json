{
  "apiVersion": 3,
  "title": "Dynamic Spacer",
  "name": "mwf/dynamic-spacer",
  "category": "design",
  "description": "Add white space between blocks and customize its relative to another element.",
  "icon": "editor-code",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "editorStyle": "file:./index.css",
  "attributes": {
    "spacerHeight": {
      "type": "string",
      "default": "100px"
    },
    "relativeTo": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "anchor": true,
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "__experimentalDefaultControls": {
        "margin": true
      }
    },
    "interactivity": {
      "clientNavigation": true
    }
  }
}