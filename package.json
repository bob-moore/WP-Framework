{
	"name": "placeholder_plugin",
	"version": "4.0.1",
	"description": "Starter plugin framework",
	"author": "Plugin Author <author@example.com>",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"mu-plugin",
		"project",
		"wordpress"
	],
	"homepage": "https://example.com",
	"repository": "https://github.com/vendor/{PROJECT}",
	"bugs": "https://github.com/vendor/{PROJECT}/issues",
	"devDependencies": {
		"@wordpress/block-editor": "^15.16.0",
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/scripts": "^31.8.0",
		"autoprefixer": "^10.5.0",
		"mini-css-extract-plugin": "^2.10.2",
		"postcss": "^8.5.9",
		"postcss-pxtorem": "^6.1.0",
		"sass": "^1.99.0",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"scripts": {
		"build": "npm run fix:css && npm run fix:js && npm run compile",
		"compile": "wp-scripts build --webpack-copy-php --experimental-modules",
		"start": "wp-scripts start --webpack-copy-php --experimental-modules",
		"start:hot": "wp-scripts start --hot",
		"block-manifest": "wp-scripts build-blocks-manifest --output=build/manifest.php",
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses --prod --gpl2",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style './src/**/*.scss'",
		"fix:css": "wp-scripts lint-style './src/**/*.scss' --fix",
		"lint:js": "wp-scripts lint-js './src/**/*.ts' './src/**/*.tsx'",
		"fix:js": "wp-scripts lint-js './src/**/*.ts' './src/**/*.tsx' --fix",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"test:e2e": "wp-scripts test-e2e",
		"test:unit": "wp-scripts test-unit-js",
		"update:all": "npx npm-check-updates -u"
	},
	"browserslist": [
		"last 3 version",
		"> 1%",
		"not dead"
	],
	"dependencies": {},
	"files": [ 
		"dist",
		"includes",
		"vendor"
	]
}
